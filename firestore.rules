rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- COLLECTION: Users ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && incoming().keys().hasAll(['email'])
        && incoming().email is string
        && incoming().email.size() <= 200;
      allow update: if isOwner(userId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['email', 'lastSynced']);

      // --- SUB-COLLECTION: API Keys ---
      match /config/apiKeys {
        allow get: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && incoming().keys().hasAll(['keys', 'updatedAt'])
          && incoming().keys is list
          && incoming().keys.size() <= 20
          && incoming().updatedAt == request.time;
      }

      // --- SUB-COLLECTION: Sessions ---
      match /sessions/{sessionId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidId(sessionId)
          && incoming().keys().hasAll(['id', 'title', 'messages', 'userInfo', 'updatedAt'])
          && incoming().id == sessionId
          && incoming().updatedAt == request.time;
        allow update: if isOwner(userId)
          && incoming().updatedAt == request.time
          && incoming().id == existing().id // Immutable ID
          && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'messages', 'userInfo', 'updatedAt']);
        allow delete: if isOwner(userId);
      }
    }
  }
}
